# Environment variables - NOT committed
# Copy this file to .env.local and update values for local development

# JWT secret (minimum 32 characters for HS512)
JWT_SECRET=chaintrack-local-secret-key-min-32-characters-here

# Frontend URL for CORS (development)
FRONTEND_URL=http://localhost:5173

# Database credentials (local PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/chaintrack
DB_USERNAME=postgres
DB_PASSWORD=password